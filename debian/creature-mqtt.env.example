# OpenTelemetry configuration for creature-mqtt
# Copy to /etc/default/creature-mqtt and fill in your API key.
# All variables are optional — without them, OTel silently degrades to console-only.

OTEL_SERVICE_NAME=creature-mqtt
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_API_KEY_HERE
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
