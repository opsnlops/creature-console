# Creature MQTT Bridge configuration
# Copy to /etc/default/creature-mqtt and edit for your environment.

# Creature server
CREATURE_SERVER_HOST=server.prod.chirpchirp.dev
CREATURE_SERVER_PORT=443

# MQTT broker
MQTT_HOST=home.opsnlops.io
MQTT_PORT=1883

# OpenTelemetry (uncomment to enable OTLP export; without these, console-only logging is used)
#OTEL_SERVICE_NAME=creature-mqtt
#OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
#OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_API_KEY_HERE
#OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
