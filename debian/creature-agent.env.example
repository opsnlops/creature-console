# Creature Agent configuration
# Copy to /etc/default/creature-agent and edit for your environment.

# Creature server
CREATURE_SERVER_HOST=server.prod.chirpchirp.dev
CREATURE_SERVER_PORT=443

# OpenTelemetry (optional — without these, OTel silently degrades to console-only)
OTEL_SERVICE_NAME=creature-agent
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_API_KEY_HERE
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
